# ============================================================
# Docker / docker-compose environment overrides
# Copy this to .env and fill in your real values
# ============================================================
# SECURITY: chmod 600 .env  |  NEVER commit .env
# ============================================================

# -- MCP Server -----------------------------------------------
NODE_ENV=development
MCP_SERVER_PORT=3000
MCP_LOG_LEVEL=info

# -- n8n ------------------------------------------------------
# Inside docker-compose, services talk to each other by name.
# From your Mac browser you still use localhost:5678.
N8N_HOST=n8n
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://n8n:5678/webhook
N8N_ENCRYPTION_KEY=CHANGE_THIS_TO_A_RANDOM_STRING
# Stripe billing events fan-out — set to your n8n Webhook Trigger node URL
N8N_STRIPE_WEBHOOK_URL=http://n8n:5678/webhook/stripe-billing

# -- Anthropic ------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -- GitHub ---------------------------------------------------
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE
GITHUB_USERNAME=crystalclearhouse-data

# -- Supabase -------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Service role key needed for billing writes — NEVER expose to browser clients
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# -- Stripe ---------------------------------------------------
# Use sk_test_* / whsec_* locally; swap for live keys in production
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY
# Get webhook secret from: npm run stripe:listen --print-secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET
